# Dashboard
PROJECT_NAME=Portabase
PROJECT_URL=http://localhost:80

# Generate with e.g. openssl rand -hex 32
PROJECT_SECRET=<32_HEX_TOKEN>

# DB
POSTGRES_DB=portabase
POSTGRES_USER=portabase
POSTGRES_PASSWORD=<SUPER_SECURE_PASSWORD>
POSTGRES_HOST=db

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}?schema=public

# Agent
TZ=Europe/Berlin
POLLING=5
APP_ENV=production
DATA_PATH=/data
LOG=info
EDGE_KEY=<YOUR_EDGE_KEY>